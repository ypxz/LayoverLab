# --- Database ---
DATABASE_URL=postgresql+psycopg://layover:layover@localhost:5433/layoverlab
# inside docker-compose the api/worker use: postgresql+psycopg://layover:layover@db:5432/layoverlab
# no Docker/Postgres? SQLite works for local dev (single worker):
# DATABASE_URL=sqlite:///layoverlab.sqlite3

# --- Crawler ---
CRAWL_ENABLED=true            # global kill-switch for all outbound crawling
CRAWL_MIN_INTERVAL_S=2.0      # per-domain minimum seconds between requests
CRAWL_BREAKER_COOLDOWN_S=300  # per-domain circuit breaker: seconds before half-open probe
HTTP_CACHE_DIR=.cache/http    # on-disk response cache (relative to server/)

# --- Connectors ---
# Travelpayouts covers ALL airlines from Aviasales market cache — highest-value token.
# Free signup (~5 min): https://www.travelpayouts.com -> sign up -> Tools -> API -> copy token
TRAVELPAYOUTS_TOKEN=
# Kiwi Tequila: free tier, natively prices self-transfer itineraries.
# Signup: https://tequila.kiwi.com -> create account -> My solutions -> create Search API key
TEQUILA_API_KEY=
# Amadeus Self-Service (official, free monthly test quota; used verify-first).
# Signup: https://developers.amadeus.com -> Self-Service -> create app -> copy API Key/Secret
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
WIZZ_ENABLED=true             # Wizz Air public timetable endpoint (no key)
EASYJET_ENABLED=true          # easyJet lowest-daily-fares endpoint (no key)
GF_ENABLED=false              # Google Flights verification connector (low volume)

# --- API ---
API_CORS_ORIGINS=http://localhost:3000

# --- Web ---
NEXT_PUBLIC_API_BASE=http://localhost:8000/api
