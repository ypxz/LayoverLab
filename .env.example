# --- Database ---
DATABASE_URL=postgresql+psycopg://layover:layover@localhost:5433/layoverlab
# inside docker-compose the api/worker use: postgresql+psycopg://layover:layover@db:5432/layoverlab
# no Docker/Postgres? SQLite works for local dev (single worker):
# DATABASE_URL=sqlite:///layoverlab.sqlite3

# --- Crawler ---
CRAWL_ENABLED=true            # global kill-switch for all outbound crawling
CRAWL_MIN_INTERVAL_S=2.0      # per-domain minimum seconds between requests
HTTP_CACHE_DIR=.cache/http    # on-disk response cache (relative to server/)

# --- Connectors ---
TRAVELPAYOUTS_TOKEN=          # free token: https://www.travelpayouts.com -> Tools -> API
GF_ENABLED=false              # Google Flights verification connector (low volume)

# --- API ---
API_CORS_ORIGINS=http://localhost:3000
# max seconds an /api/search SSE stream stays open waiting for fresh fares
SEARCH_STREAM_MAX_S=60
# poll interval while waiting for a cold route's fares to land
SEARCH_STREAM_POLL_S=5.0
# in-process per-IP rate limiting (429 + Retry-After)
RATE_LIMIT_ENABLED=true
# /api/search requests per minute per client IP
RATE_SEARCH_PER_MIN=10
# all other endpoints, per minute per client IP
RATE_DEFAULT_PER_MIN=60
# empty = /api/admin/* hidden (404); set to enable the admin surface
ADMIN_TOKEN=
# expose Prometheus metrics at /api/metrics
METRICS_ENABLED=true

# --- Web ---
NEXT_PUBLIC_API_BASE=http://localhost:8000/api
