  "info": {
    "description": "Creative cheapest-route flight finder: cached candidates, live verification, streaming updates.",
    "title": "LayoverLab API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/airports": {
      "get": {
        "operationId": "airports_api_airports_get",
        "parameters": [
          {
            "in": "query",
            "name": "q",
            "required": true,
            "schema": {
              "maxLength": 64,
              "minLength": 2,
              "title": "Q",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/AirportOut"
                  },
                  "title": "Response Airports Api Airports Get",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Airports",
        "tags": [
          "airports"
        ]
      }
    },
    "/api/health": {
      "get": {
        "operationId": "health_api_health_get",
