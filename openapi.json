              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Itinerary",
        "tags": [
          "itineraries"
        ]
      }
    },
    "/api/search": {
      "post": {
        "description": "SSE stream: `candidates` -> `verified` -> zero or more `update` -> `done`.",
        "operationId": "search_endpoint_api_search_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SearchParams",
                "examples": [
                  {
                    "date_from": "2026-08-01",
                    "date_to": "2026-08-31",
                    "dest": "ALC",
                    "max_stops": 3,
                    "origin": "BER",
                    "round_trip": false,
                    "top_k": 10
                  }
                ]
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Streaming cheapest-route search",
        "tags": [
          "search"
        ]
      }
    }
